{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "PlatformIO Build",
			"type": "shell",
			"command": "platformio",
			"args": [
				"run",
				"-e",
				"photo_frame_gs_01"
			],
			"problemMatcher": [
				"$platformio"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "PlatformIO Test",
			"type": "shell",
			"command": "platformio",
			"args": [
				"test",
				"-e",
				"native"
			],
			"problemMatcher": [
				"$platformio"
			],
			"group": {
				"kind": "test",
				"isDefault": true
			}
		}
	]
}